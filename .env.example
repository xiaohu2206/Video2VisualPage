# Copy to .env and fill the values for your model provider.
# Legacy VIDEO2VISUALPAGE_LLM_* values are still used as shared fallbacks.

# Shared defaults for both model roles.
VIDEO2VISUALPAGE_LLM_OUTPUT_LANGUAGE=zh-CN
VIDEO2VISUALPAGE_LLM_JSON_MODE=1
VIDEO2VISUALPAGE_LLM_TIMEOUT=300
VIDEO2VISUALPAGE_LLM_MAX_RETRIES=2
VIDEO2VISUALPAGE_LLM_RATE_LIMIT_PER_MINUTE=300

# Vision model: used by 06_shot_understanding for image/keyframe understanding.
VIDEO2VISUALPAGE_VISION_MODEL_PROVIDER=openai_compatible
VIDEO2VISUALPAGE_VISION_MODEL_BASE_URL=https://api.openai.com/v1
VIDEO2VISUALPAGE_VISION_MODEL_MODEL=
VIDEO2VISUALPAGE_VISION_MODEL_API_KEY=
VIDEO2VISUALPAGE_VISION_MODEL_TEMPERATURE=0.2
VIDEO2VISUALPAGE_VISION_MODEL_VISION_ENABLED=1
VIDEO2VISUALPAGE_VISION_MODEL_MAX_IMAGES_PER_SHOT=1

# Copywriting model: used by 07_summary_reduce and 09_chapter_write.
# Put your higher-quality text model here.
VIDEO2VISUALPAGE_COPYWRITING_MODEL_PROVIDER=openai_compatible
VIDEO2VISUALPAGE_COPYWRITING_MODEL_BASE_URL=https://api.openai.com/v1
VIDEO2VISUALPAGE_COPYWRITING_MODEL_MODEL=
VIDEO2VISUALPAGE_COPYWRITING_MODEL_API_KEY=
VIDEO2VISUALPAGE_COPYWRITING_MODEL_TEMPERATURE=0.35
